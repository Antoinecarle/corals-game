{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "preserve",
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@pirate-mmo/shared": [
        "../shared/src"
      ]
    },
    "types": [
      "vite/client"
    ]
  },
  "include": [
